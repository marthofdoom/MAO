{
	"modName": "MAO",
	"displayName": "Marth's Alchemy Overhaul",
	"minMcmVersion": 9,
	"cursorFillMode": "topToBottom",
	"pages": [
		{
			"pageDisplayName": "Field Kit",
			"cursorFillMode": "topToBottom",
			"content": [
				{
					"text": "General",
					"type": "header"
				},
				{
					"id": "bConversionEnabled:General",
					"text": "Convert ingredients to essence",
					"type": "toggle",
					"help": "When ON, harvested and picked-up ingredients (and potions) are consumed into essence. When OFF, they stay in your inventory as normal items and nothing is converted. Flasks, the field kit, and perks are unaffected. Applies when you close the menu.",
					"valueOptions": {
						"sourceType": "ModSettingBool",
						"defaultValue": true
					}
				},
				{
					"text": "Economy",
					"type": "header"
				},
				{
					"id": "fEssenceTax:Economy",
					"text": "Essence tax",
					"type": "slider",
					"help": "Convenience tax multiplier on flask cost vs. the vanilla recipe. 1.3 = +30%.",
					"valueOptions": {
						"min": 1.0,
						"max": 5.0,
						"step": 0.05,
						"formatString": "{2}",
						"sourceType": "ModSettingFloat",
						"defaultValue": 1.3
					}
				},
				{
					"id": "fCostRate:Economy",
					"text": "Cost rate (global scale)",
					"type": "slider",
					"help": "Scales all flask essence costs up or down.",
					"valueOptions": {
						"min": 0.05,
						"max": 20.0,
						"step": 0.05,
						"formatString": "{2}",
						"sourceType": "ModSettingFloat",
						"defaultValue": 1.0
					}
				},
				{
					"id": "fCatalystQuality:Economy",
					"text": "Catalyst quality threshold",
					"type": "slider",
					"help": "Potion quality ABOVE which a flask requires Catalyst essence regardless of its ingredients. Log scale: 1.0 = your load order's quality anchor (the cheapest real potions), +0.5 = twice the gold value. Max = off.",
					"valueOptions": {
						"min": 0.5,
						"max": 4.0,
						"step": 0.1,
						"formatString": "{1}",
						"sourceType": "ModSettingFloat",
						"defaultValue": 1.0
					}
				},
				{
					"id": "iApexTopRungs:Economy",
					"text": "Apex-guaranteed top rungs",
					"type": "slider",
					"help": "How many TOP rungs of a potion's own family require Apex essence. 2 = the strongest and the one below it (e.g. Surpassing and Remarkable). 0 = off.",
					"valueOptions": {
						"min": 0,
						"max": 5,
						"step": 1,
						"formatString": "{0}",
						"sourceType": "ModSettingInt",
						"defaultValue": 2
					}
				},
				{
					"id": "fApexQuality:Economy",
					"text": "Apex quality fallback",
					"type": "slider",
					"help": "Absolute quality at which a flask requires Apex even with no potion family to be the top rung of (a one-off legendary). Max = off.",
					"valueOptions": {
						"min": 1.0,
						"max": 4.0,
						"step": 0.1,
						"formatString": "{1}",
						"sourceType": "ModSettingFloat",
						"defaultValue": 2.5
					}
				},
				{
					"id": "iRefillSeconds:Economy",
					"text": "Refill interval (seconds)",
					"type": "slider",
					"help": "Real-time seconds between automatic flask refill passes. Sleeping also refills.",
					"valueOptions": {
						"min": 15,
						"max": 3600,
						"step": 15,
						"formatString": "{0}",
						"sourceType": "ModSettingInt",
						"defaultValue": 300
					}
				},
				{
					"text": "Interface",
					"type": "header"
				},
				{
					"id": "iMenuStyle:Interface",
					"text": "Field Kit skin",
					"type": "enum",
					"help": "Menu color theme.",
					"valueOptions": {
						"options": [
							"Ebony & Brass",
							"Dwemer Parchment",
							"Soul Cairn",
							"Quicksilver"
						],
						"shortNames": [
							"Ebony & Brass",
							"Dwemer Parchment",
							"Soul Cairn",
							"Quicksilver"
						],
						"sourceType": "ModSettingInt"
					}
				},
				{
					"id": "bNotify:Interface",
					"text": "Gathering notifications",
					"type": "toggle",
					"help": "Show on-screen essence notifications when gathering ingredients.",
					"valueOptions": {
						"sourceType": "ModSettingBool",
						"defaultValue": true
					}
				}
			]
		},
